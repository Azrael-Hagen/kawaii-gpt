{
  "name": "kawaii-gpt",
  "version": "0.4.20",
  "description": "Your adorable AI companion — KawaiiGPT",
  "author": "Azrael",
  "homepage": "https://github.com/Azrael-Hagen/kawaii-gpt",
  "repository": {
    "type": "git",
    "url": "https://github.com/Azrael-Hagen/kawaii-gpt.git"
  },
  "bugs": {
    "url": "https://github.com/Azrael-Hagen/kawaii-gpt/issues"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@fontsource/nunito": "^5.0.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.kawaiigpt.app",
    "productName": "KawaiiGPT",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Azrael-Hagen",
      "repo": "kawaii-gpt"
    },
    "nsis": {
      "artifactName": "KawaiiGPT-${version}-setup-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KawaiiGPT",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "portable": {
      "artifactName": "KawaiiGPT-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}
